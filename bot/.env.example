# Plantilla de variables de entorno. Copia a bot/.env y rellena tus claves.
# bot/.env está en .gitignore — nunca lo subas al repositorio.

# --- Embeddings (indexer + retriever) ---
# Token de Hugging Face para evitar el rate limit anónimo al descargar el modelo.
HF_TOKEN=tu_token_de_hugging_face

# --- Generación y NLU ---
# Clave de Google AI Studio (Gemini). Se usa para el NLU y, por defecto, para la generación.
GOOGLE_API_KEY=tu_google_api_key

# Proveedor del LLM de generación de la respuesta final: "gemini" (por defecto) u "openrouter".
PROVEEDOR_LLM=gemini

# Modelo de generación cuando PROVEEDOR_LLM=gemini.
MODELO_GENERACION=gemini-2.0-flash

# --- OpenRouter (solo si PROVEEDOR_LLM=openrouter) ---
# Permite usar otros modelos a través de una API compatible con OpenAI.
OPENROUTER_API_KEY=tu_openrouter_api_key
OPENROUTER_MODEL=google/gemini-2.0-flash-001
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
